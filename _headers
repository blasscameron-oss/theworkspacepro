/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: blob: https:; connect-src 'self' https://www.google-analytics.com https://static.cloudflareinsights.com https://cloudflareinsights.com https://formspree.io; form-action https://formspree.io https://beehiiv.com https://*.beehiiv.com; frame-src 'none'; object-src 'none'; base-uri 'self'
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=()
  Strict-Transport-Security: max-age=31536000
  Link: </assets/css/fonts.css>; rel=preload; as=style
  Link: </assets/css/style.css>; rel=preload; as=style

/assets/*
  Cache-Control: public, max-age=86400, must-revalidate

/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

/assets/images/*
  Cache-Control: public, max-age=2592000, must-revalidate

/*.svg
  Cache-Control: public, max-age=604800, must-revalidate

/favicon.svg
  Cache-Control: public, max-age=604800, must-revalidate

# Operational paths must never be cached if they are requested after removal.
# The Pages allowlist intentionally does not publish these files.
/FINCH_HANDOFF.md
  Cache-Control: no-store
  X-Robots-Tag: noindex

/worker/*
  Cache-Control: no-store
  X-Robots-Tag: noindex


# Embeddable tools — detach inherited frame/CSP then re-set open framing
/embed/*
  ! X-Frame-Options
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://static.cloudflareinsights.com https://cloudflareinsights.com; frame-ancestors *; object-src 'none'; base-uri 'self'
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
