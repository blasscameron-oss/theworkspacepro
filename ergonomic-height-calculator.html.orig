<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ergonomic Height Calculator — Desk, Chair & Monitor Starting Ranges - The Workspace Pro</title>
  <meta name="description" content="Free ergonomic height estimator. Enter your height for transparent desk, chair, monitor, and keyboard starting points and adjustment ranges in inches or cm.">
  <meta property="og:title" content="Ergonomic Height Calculator — The Workspace Pro">
  <meta property="og:description" content="Estimate desk, chair, and monitor starting points and adjustment ranges based on your height. Free interactive tool.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://www.theworkspacepro.com/ergonomic-height-calculator">
  <meta property="og:image" content="https://www.theworkspacepro.com/assets/images/og-default.jpg">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Ergonomic Height Calculator">
  <meta name="twitter:description" content="Estimate desk, chair, and monitor starting ranges in seconds.">
