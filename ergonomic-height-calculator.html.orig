  <!-- JSON-LD structured data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Ergonomic Height Calculator",
    "description": "Interactive tool that estimates desk, chair, keyboard, and monitor starting points and adjustment ranges based on the user's body height.",
    "url": "https://www.theworkspacepro.com/ergonomic-height-calculator",
    "applicationCategory": "HealthApplication",
    "operatingSystem": "Web Browser",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "publisher": {
      "@type": "Organization",
      "name": "The Workspace Pro",
      "url": "https://www.theworkspacepro.com"
    }
  }
  </script>
  <style>
    /* Tool-specific styles */
    .ehc-tool { max-width: 1100px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }
    .ehc-layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-2xl); align-items: start; }
    @keyframes ehcFade { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    .ehc-animate { animation: ehcFade 0.4s ease; }

    /* Input section */
    .ehc-card { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius-lg); padding: var(--space-xl); box-shadow: var(--shadow-md); }
    .ehc-card::before { content: ''; display: block; height: 4px; background: linear-gradient(90deg, var(--c-primary), var(--c-accent)); border-radius: var(--radius-lg) var(--radius-lg) 0 0; margin: calc(-1 * var(--space-xl)) calc(-1 * var(--space-xl)) var(--space-xl); }

    .ehc-unit-toggle { display: flex; gap: 0; margin-bottom: var(--space-lg); border: 2px solid var(--c-border); border-radius: var(--radius); overflow: hidden; width: fit-content; }
    .ehc-unit-btn { padding: var(--space-sm) var(--space-lg); font-size: 0.9rem; font-weight: 600; background: var(--c-surface); color: var(--c-text-light); border: none; cursor: pointer; transition: all var(--t-fast); }
    .ehc-unit-btn.active { background: var(--c-primary); color: white; }
    .ehc-unit-btn:not(.active):hover { background: var(--c-bg-alt); }

    .ehc-height-display { font-family: var(--font-display); font-size: 3rem; font-weight: 700; color: var(--c-primary); text-align: center; margin: var(--space-sm) 0; line-height: 1.1; }
    .ehc-slider { width: 100%; height: 8px; -webkit-appearance: none; appearance: none; background: var(--c-border); border-radius: 4px; outline: none; margin: var(--space-md) 0; }
    .ehc-slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 28px; height: 28px; border-radius: 50%; background: var(--c-primary); cursor: pointer; box-shadow: var(--shadow-md); border: 3px solid var(--c-surface); }
    .ehc-slider::-moz-range-thumb { width: 28px; height: 28px; border-radius: 50%; background: var(--c-primary); cursor: pointer; border: 3px solid var(--c-surface); }

    .ehc-label { font-weight: 500; font-size: 0.9rem; color: var(--c-text-light); margin-bottom: var(--space-xs); }

    /* Results grid */
    .ehc-results { display: flex; flex-direction: column; gap: var(--space-md); }
    .ehc-result-row { display: flex; justify-content: space-between; align-items: center; padding: var(--space-md) var(--space-lg); background: var(--c-bg-alt); border-radius: var(--radius); border-left: 4px solid var(--c-primary); transition: background var(--t-fast); }
    .ehc-result-row:hover { background: var(--c-border); }
    .ehc-result-label { font-weight: 500; font-size: 0.95rem; }
    .ehc-result-label small { display: block; font-weight: 400; font-size: 0.8rem; color: var(--c-text-muted); margin-top: 2px; }
    .ehc-result-value { font-family: var(--font-mono); font-size: 1.2rem; font-weight: 700; color: var(--c-text); }
    .ehc-result-unit { font-size: 0.85rem; font-weight: 400; color: var(--c-text-muted); margin-left: var(--space-xs); }
    .ehc-result-output { text-align: right; flex: 0 0 auto; margin-left: var(--space-md); }
    .ehc-result-range { display: block; margin-top: 2px; color: var(--c-text-muted); font-size: 0.72rem; font-weight: 500; white-space: nowrap; }
    .ehc-result-icon { font-size: 1.3rem; margin-right: var(--space-sm); }

    .ehc-result-highlight { border-left-color: var(--c-accent); }
    .ehc-result-highlight .ehc-result-value { color: var(--c-accent); }

    /* SVG illustration */
    .ehc-svg-wrap { width: 100%; max-width: 350px; margin: 0 auto; }
    .ehc-svg-wrap svg { width: 100%; height: auto; }

    /* Share / print */
    .ehc-actions { display: flex; gap: var(--space-sm); flex-wrap: wrap; margin-top: var(--space-xl); }
    .ehc-action-btn { padding: var(--space-sm) var(--space-lg); border: 1px solid var(--c-border); border-radius: var(--radius); background: var(--c-surface); cursor: pointer; font-size: 0.85rem; font-weight: 500; transition: all var(--t-fast); display: inline-flex; align-items: center; gap: var(--space-xs); }
    .ehc-action-btn:hover { background: var(--c-bg-alt); border-color: var(--c-primary); }
    .ehc-action-btn--primary { background: var(--c-primary); color: white; border-color: var(--c-primary); }
    .ehc-action-btn--primary:hover { background: var(--c-primary-dark); }

    /* Info section */
    .ehc-info { background: var(--c-bg-alt); border-radius: var(--radius-lg); padding: var(--space-xl); margin-top: var(--space-xl); font-size: 0.95rem; line-height: 1.7; }
    .ehc-info h3 { font-family: var(--font-display); margin-bottom: var(--space-sm); }
    .ehc-info ul { list-style: none; padding: 0; }
    .ehc-info li { padding: var(--space-xs) 0; padding-left: var(--space-lg); position: relative; }
    .ehc-info li::before { content: '—'; position: absolute; left: 0; color: var(--c-primary); }
    .ehc-tip { background: var(--c-surface); border: 1px solid var(--c-border); border-radius: var(--radius); padding: var(--space-md); margin-top: var(--space-md); font-size: 0.9rem; color: var(--c-text-light); }

    [data-theme="dark"] .ehc-card { background: var(--c-dark-surface); border-color: var(--c-dark-border); }
    [data-theme="dark"] .ehc-result-row { background: var(--c-dark-surface); }
    [data-theme="dark"] .ehc-result-row:hover { background: var(--c-dark-border); }
    [data-theme="dark"] .ehc-action-btn { background: var(--c-dark-surface); border-color: var(--c-dark-border); }
    [data-theme="dark"] .ehc-info { background: var(--c-dark-surface); }
    [data-theme="dark"] .ehc-tip { background: var(--c-dark-surface); border-color: var(--c-dark-border); }

    @media (max-width: 768px) {
      .ehc-layout { grid-template-columns: 1fr; gap: var(--space-lg); }
      .ehc-height-display { font-size: 2.2rem; }
    }
  </style>
<link rel="stylesheet" href="/assets/css/reviews.css">
  <link rel="icon" href="/assets/images/favicon.svg" type="image/svg+xml">
