  <script src="/assets/js/height-math.js"></script>
  <script src="/assets/js/analytics.js" defer></script>
  <script src="/assets/js/site.js" defer></script>
  <script src="/assets/js/perf-lite.js" defer></script>
<script src="/assets/js/enhancements.js" defer></script>
  <script src="/assets/js/bold.js" defer></script>
  <script>
  // =========================================
  // EHC — Ergonomic Height Calculator
  // Vanilla JS, zero dependencies
  // =========================================

  (function() {
    var unit = 'imperial'; // 'imperial' | 'metric'
    var heightSlider = document.getElementById('heightSlider');
    var heightDisplay = document.getElementById('heightDisplay');

    // Result elements
    var els = {
      standingDesk: document.getElementById('standingDesk'),
      standingDeskUnit: document.getElementById('standingDeskUnit'),
      sittingDesk: document.getElementById('sittingDesk'),
      sittingDeskUnit: document.getElementById('sittingDeskUnit'),
      chairHeight: document.getElementById('chairHeight'),
      chairHeightUnit: document.getElementById('chairHeightUnit'),
      monitorHeight: document.getElementById('monitorHeight'),
      monitorHeightUnit: document.getElementById('monitorHeightUnit'),
      monitorDistance: document.getElementById('monitorDistance'),
      monitorDistanceUnit: document.getElementById('monitorDistanceUnit'),
      keyboardHeight: document.getElementById('keyboardHeight'),
      keyboardHeightUnit: document.getElementById('keyboardHeightUnit'),
      standingDeskRange: document.getElementById('standingDeskRange'),
      sittingDeskRange: document.getElementById('sittingDeskRange'),
      chairHeightRange: document.getElementById('chairHeightRange'),
      monitorHeightRange: document.getElementById('monitorHeightRange'),
      monitorDistanceRange: document.getElementById('monitorDistanceRange'),
      keyboardHeightRange: document.getElementById('keyboardHeightRange')
    };

    function getHeightInches() {
      return parseFloat(heightSlider.value);
    }

    function formatHeight(inches) {
      if (unit === 'metric') {
        return Math.round(inches * 2.54) + ' cm';
      }
      var ft = Math.floor(inches / 12);
      var inchRem = Math.round(inches % 12);
      return ft + "'" + inchRem + '"';
    }

    function toDisplayValue(inches) {
      var value = unit === 'metric' ? TWPHeightMath.inchesToCm(inches) : TWPHeightMath.roundVal(inches);
      return value.toFixed(1);
    }

    function toUnitSuffix() {
      return unit === 'metric' ? ' cm' : ' in';
    }

    function formatRange(range) {
      return 'Range ' + toDisplayValue(range.min) + '–' + toDisplayValue(range.max) + toUnitSuffix();
    }

    function updateAll() {
      var h = getHeightInches(); // total height in inches

      var estimates = TWPHeightMath.computeFromInches(h);
      var ranges = TWPHeightMath.computeRangesFromInches(h);

      // Update height display
      heightDisplay.textContent = formatHeight(h);
      heightSlider.setAttribute('aria-valuetext', formatHeight(h));

      // Update results
      els.standingDesk.textContent = toDisplayValue(estimates.standingDesk);
      els.standingDeskUnit.textContent = toUnitSuffix();
      els.standingDeskRange.textContent = formatRange(ranges.standingDesk);
      els.sittingDesk.textContent = toDisplayValue(estimates.sittingDesk);
      els.sittingDeskUnit.textContent = toUnitSuffix();
      els.sittingDeskRange.textContent = formatRange(ranges.sittingDesk);
      els.chairHeight.textContent = toDisplayValue(estimates.chair);
      els.chairHeightUnit.textContent = toUnitSuffix();
      els.chairHeightRange.textContent = formatRange(ranges.chair);
      els.monitorHeight.textContent = toDisplayValue(estimates.monitorTop);
      els.monitorHeightUnit.textContent = toUnitSuffix();
      els.monitorHeightRange.textContent = formatRange(ranges.monitorTop);
      els.monitorDistance.textContent = toDisplayValue(estimates.monitorDistance);
      els.monitorDistanceUnit.textContent = toUnitSuffix();
      els.monitorDistanceRange.textContent = formatRange(ranges.monitorDistance);
      els.keyboardHeight.textContent = toDisplayValue(estimates.keyboard);
      els.keyboardHeightUnit.textContent = toUnitSuffix();
      els.keyboardHeightRange.textContent = formatRange(ranges.keyboard);

      // Update SVG illustration
      updateSvg(h);
    }

    function updateSvg(h) {
      var svg = document.getElementById('ehcSvg');

      // Person proportions scale with height
      var scaleFactor = h / 69; // relative to 5'9" (69 inches)
      var baseHeadY = 75 / scaleFactor;
      var baseNeckY = 93 / scaleFactor;
      var baseTorsoY = 108 / scaleFactor;
      var baseTorsoH = 55 * scaleFactor;
      var baseArmEndY = 155 * scaleFactor;
      var baseDeskY = 155 * scaleFactor;

      var head = document.getElementById('ehcHead');
      var neck = document.getElementById('ehcNeck');
      var torso = document.getElementById('ehcTorso');
      var armL = document.getElementById('ehcArmL');
      var armR = document.getElementById('ehcArmR');
      var deskSurface = document.getElementById('ehcDeskSurface');
      var deskLegL = document.getElementById('ehcDeskLegL');
      var deskLegR = document.getElementById('ehcDeskLegR');
      var monitor = document.getElementById('ehcMonitor');
      var monitorStand = document.getElementById('ehcMonitorStand');
      var eyeLine = document.getElementById('ehcEyeLine');

      // Desk height from calculation
      var standingDeskInches = TWPHeightMath.computeFromInches(h).standingDesk;
      var deskY = Math.max(100, 320 - standingDeskInches * 2.5); // map inches to SVG coords
      deskY = Math.min(220, deskY);

      // Head at ~25% of body from top
      var headY = Math.max(20, deskY - 90 * scaleFactor);

      // Update positions
      head.setAttribute('cy', headY);
      neck.setAttribute('y1', headY + 18);
      neck.setAttribute('y2', headY + 35);
      torso.setAttribute('y', headY + 33);
      torso.setAttribute('height', Math.max(20, deskY - headY - 38));

      // Arms to desk surface
      var armStartY = headY + 40;
      armL.setAttribute('y1', armStartY);
      armL.setAttribute('y2', deskY - 3);
      armR.setAttribute('y1', armStartY);
      armR.setAttribute('y2', deskY - 3);

      // Desk
      deskSurface.setAttribute('y', deskY - 3);
      deskLegL.setAttribute('y1', deskY + 3);
      deskLegR.setAttribute('y1', deskY + 3);
      deskLegL.setAttribute('y2', 300);
      deskLegR.setAttribute('y2', 300);

      // Monitor — sits on desk
      var monitorH = Math.max(20, 40 * scaleFactor);
      monitor.setAttribute('y', deskY - 3 - monitorH);
      monitor.setAttribute('height', monitorH);
      monitorStand.setAttribute('y1', deskY - 3);
      monitorStand.setAttribute('y2', deskY - 3 - monitorH + 5);

      // Eye level line — at head center
      eyeLine.setAttribute('y1', headY);
      eyeLine.setAttribute('y2', headY);
      var eyeText = svg.querySelector('text');
      if (eyeText) {
        eyeText.setAttribute('y', headY + 3);
      }
    }

    // ---- Share / Print ----

    function trackAction(action) {
      if (typeof window.gtag === 'function') {
        window.gtag('event', 'height_calculator_action', { action: action });
      }
    }

    function ehcPrint() {
      trackAction('print');
      window.print();
    }

    function ehcCopyResults(button) {
      var h = getHeightInches();
      var estimates = TWPHeightMath.computeFromInches(h);
      var ranges = TWPHeightMath.computeRangesFromInches(h);
      var lines = [
        'My Estimated Ergonomic Starting Ranges (via The Workspace Pro)',
        'Height: ' + formatHeight(h),
        '',
        '• Standing Desk Height: ' + toDisplayValue(estimates.standingDesk) + toUnitSuffix() + ' (' + formatRange(ranges.standingDesk).toLowerCase() + ')',
        '• Sitting Desk Height: ' + toDisplayValue(estimates.sittingDesk) + toUnitSuffix() + ' (' + formatRange(ranges.sittingDesk).toLowerCase() + ')',
        '• Chair Seat Height: ' + toDisplayValue(estimates.chair) + toUnitSuffix() + ' (' + formatRange(ranges.chair).toLowerCase() + ')',
        '• Monitor Top Height (seated): ' + toDisplayValue(estimates.monitorTop) + toUnitSuffix() + ' (' + formatRange(ranges.monitorTop).toLowerCase() + ')',
        '• Monitor Distance: ' + toDisplayValue(estimates.monitorDistance) + toUnitSuffix() + ' (' + formatRange(ranges.monitorDistance).toLowerCase() + ')',
        '• Keyboard Height: ' + toDisplayValue(estimates.keyboard) + toUnitSuffix() + ' (' + formatRange(ranges.keyboard).toLowerCase() + ')',
        '',
        'Calculate yours: https://www.theworkspacepro.com/ergonomic-height-calculator'
      ].join('\n');

      trackAction('copy');

      function showCopied() {
        var original = button.textContent;
        button.textContent = '✅ Copied!';
        setTimeout(function() { button.textContent = original; }, 2000);
      }

      function copyFallback() {
        var ta = document.createElement('textarea');
        ta.value = lines;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        showCopied();
      }

      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        navigator.clipboard.writeText(lines).then(showCopied).catch(copyFallback);
      } else {
        copyFallback();
      }
    }

    function ehcShareTwitter() {
      var h = getHeightInches();
      var estimates = TWPHeightMath.computeFromInches(h);
      var text = 'My estimated workspace starting points for ' + formatHeight(h) + ': standing desk ' + toDisplayValue(estimates.standingDesk) + toUnitSuffix() + ', chair ' + toDisplayValue(estimates.chair) + toUnitSuffix() + '. Estimate yours free at ';
      trackAction('share_x');
      window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(text) + '&url=' + encodeURIComponent('https://www.theworkspacepro.com/ergonomic-height-calculator'), '_blank', 'noopener');
    }

    function ehcShareFB() {
      trackAction('share_facebook');
      window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent('https://www.theworkspacepro.com/ergonomic-height-calculator'), '_blank', 'noopener');
    }

    // ---- Unit toggle ----
    window.ehcSetUnit = function(u) {
      unit = u;
      document.querySelectorAll('.ehc-unit-btn').forEach(function(b) {
        var selected = b.dataset.unit === u;
        b.classList.toggle('active', selected);
        b.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });

      // Update slider labels
      if (u === 'metric') {
        document.getElementById('heightMinLabel').textContent = '122 cm';
        document.getElementById('heightMaxLabel').textContent = '213 cm';
        heightSlider.min = 48;
        heightSlider.max = 84;
        heightSlider.step = 0.5;
      } else {
        document.getElementById('heightMinLabel').textContent = '4\'0"';
        document.getElementById('heightMaxLabel').textContent = '7\'0"';
        heightSlider.min = 48;
        heightSlider.max = 84;
        heightSlider.step = 0.5;
      }

      updateAll();
    };

    window.ehcPrint = ehcPrint;
    window.ehcCopyResults = ehcCopyResults;
    window.ehcShareTwitter = ehcShareTwitter;
    window.ehcShareFB = ehcShareFB;

    // ---- Event listeners ----
    heightSlider.addEventListener('input', updateAll);

    // Initial update
    updateAll();
  })();
  </script>
</body>
</html>
